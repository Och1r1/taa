# Copy this file to .env.local and fill in your Supabase project values.
# Found in Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Name of the public Storage bucket that holds the song audio files.
VITE_SUPABASE_AUDIO_BUCKET=song-audio

# ── Server-side only (used by scripts/ingest.mjs, never by the browser) ──────
# These are NOT VITE_-prefixed on purpose, so Vite never bundles them into the
# client. Keep them secret; .env.local is gitignored.
#
# Service role key: Supabase dashboard → Project Settings → API → service_role.
# Bypasses RLS to write songs/upload audio. NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
# YouTube Data API v3 key — only needed for songs ingested via search `query`.
YOUTUBE_API_KEY=your-youtube-data-api-key
